# ── REQUIRED — must be set before docker-compose up ───────────────────────────

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# Database Authentication
POSTGRES_USER=drift
POSTGRES_PASSWORD=change_me_before_use
POSTGRES_DB=drift_triage

# Redis Authentication
REDIS_PASSWORD=change_me_before_use

# Security — Emergency bypass for /promote endpoint
EMERGENCY_BYPASS_KEY=change_me_in_production

# Agent Authentication — Shared secret for agent→platform calls
AGENT_API_KEY=change_me_shared_secret

# ── OPTIONAL — defaults are shown ─────────────────────────────────────────────

# HIL Configuration
APPROVAL_TIMEOUT_MINUTES=10

# Drift Detection — Platform
DRIFT_WINDOW_SIZE=500
DRIFT_RECALC_INTERVAL=50
DRIFT_PSI_THRESHOLD_MEDIUM=0.1
DRIFT_PSI_THRESHOLD_HIGH=0.2
DRIFT_PSI_THRESHOLD_CRITICAL=0.25
DRIFT_CHI2_THRESHOLD_MEDIUM=0.05
DRIFT_CHI2_THRESHOLD_HIGH=0.01

# Agent Logic
RECENT_RETRAIN_THRESHOLD_MINUTES=30
POOR_PERFORMANCE_AUC_THRESHOLD=0.65
ECONOMIC_FEATURES=euribor3m,cons.price.idx

# Dashboard
AGENT_HIL_POLL_INTERVAL=2

# Queue
MAX_RETRIES=5
IDEMPOTENCY_TTL_RETRAIN=86400
IDEMPOTENCY_TTL_OTHER=3600

# MLflow
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://drift:${POSTGRES_PASSWORD}@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# Service URLs (Docker Compose handles these, override if needed)
PLATFORM_URL=http://platform:8001
AGENT_URL=http://agent:8002
MLFLOW_TRACKING_URI=http://mlflow:5000

# Postgres Connection (used by services)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Connection (used by services)
REDIS_HOST=redis
REDIS_PORT=6379